{
  "name": "Street-Fighter",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Modules": {
        "$className": "Folder",
        "Client": {
          "$path": "src/shared/Modules/Client"
        },
        "Shared": {
          "$path": "src/shared/Modules/Shared"
        },
        "Utility": {
          "$path": "src/shared/Modules/Utility"
        }
      },
      "Networking": {
        "$className": "Folder",
        "$path": "src/shared/Networking",
        "ClientReady": {
          "$className": "RemoteFunction"
        },
        "SetControlsEnabled": {
          "$className": "RemoteEvent"
        }
      },
      "Assets": {
        "$className": "Folder",
        "Models": {
          "$path": "src/shared/Assets/Models"
        },
        "Effects": {
          "$path": "src/shared/Assets/Effects"
        },
        "Sounds": {
          "$path": "src/shared/Assets/Sounds"
        },
        "Animations": {
          "$path": "src/shared/Assets/Animations"
        }
      }
    },

    "ServerScriptService": {
      "ServerModules": {
        "$path": "src/server/ServerModules"
      },
      "loader.server.lua": {
        "$path": "src/server/loader.server.lua"
      }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "$className": "StarterPlayerScripts",
        "Starter.client.lua": {
          "$path": "src/client/Starter.client.lua"
        }
      }
    },

    "Workspace": {
      "$properties": {
        "FilteringEnabled": true
      },
      "Baseplate": {
        "$className": "Part",
        "$properties": {
          "Anchored": true,
          "Color": [
            0.38823,
            0.37254,
            0.38823
          ],
          "Locked": true,
          "Position": [
            0,
            -10,
            0
          ],
          "Size": [
            512,
            20,
            512
          ]
        }
      }
    },
    "Lighting": {
      "$properties": {
        "Ambient": [
          0,
          0,
          0
        ],
        "Brightness": 2,
        "GlobalShadows": true,
        "Outlines": false,
        "Technology": "Voxel"
      }
    },
    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}
